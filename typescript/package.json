{
    "name": "gitcc",
    "version": "2.0.13",
    "type": "module",
    "private": true,
    "author": "Iceflower S (iceflower@gmx.de)",
    "description": "TypeScript template action",
    "license": "MIT",
    "scripts": {
        "bundle": "npm run format:write && npm run package",
        "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
        "format:write": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "lint": "npx eslint .",
        "local-action": "npx @github/local-action . src/main.ts .env",
        "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
        "package:watch": "npm run package -- --watch",
        "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest --passWithNoTests",
        "all": "npm run format:write && npm run lint && npm run test && npm run package"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IceflowRE/gitcc.git"
    },
    "keywords": [
        "actions",
        "git",
        "commit",
        "checker"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "dependencies": {
        "@actions/core": "^3.0.0",
        "@actions/github": "^9.0.0"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@github/local-action": "^7.0.1",
        "@jest/globals": "^30.3.0",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "make-coverage-badge": "^1.2.0",
        "prettier": "^3.8.1",
        "rollup": "^4.59.0",
        "ts-jest": "^29.4.6",
        "ts-jest-resolver": "^2.0.1",
        "typescript": "^5.9.3"
    }
}
